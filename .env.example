# ===================================================================
# GIMS Environment Configuration Template
# ===================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control (it's already gitignored).
# ===================================================================

# Server Configuration
PORT=4000

# MongoDB Configuration
# Option 1: Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/gims

# Option 2: MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gims

# Option 3: Use in-memory database for testing (ephemeral, no persistence)
# Set to 'true' to use mongodb-memory-server instead of MONGO_URI
USE_IN_MEMORY_DB=false

# JWT Secret (CRITICAL: Change this in production!)
# Generate a strong random key:
# Node: require('crypto').randomBytes(32).toString('hex')
# Or use: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===================================================================
# Email Service Configuration (for PINs, reminders, certificates)
# ===================================================================

# Gmail Configuration (Primary)
# 1. Enable 2-Step Verification on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password (no spaces) below
GMAIL_USER=your-xu-gad-email@example.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Brevo API (Alternative email service - optional)
# Get API key from: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=your-brevo-api-key

# ===================================================================
# Branding Configuration
# ===================================================================
ORG_NAME=Xavier University – Ateneo de Cagayan
SYSTEM_NAME=GIMS

# ===================================================================
# Optional: Node Environment
# ===================================================================
# NODE_ENV=production
